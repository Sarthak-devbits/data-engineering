# PostgreSQL Connection URL (matches docker-compose.yml credentials)
DATABASE_URL="postgresql://xero_user:xero_pass@localhost:5432/xero_dataeng?schema=public"

# Xero OAuth2 Credentials
XERO_CLIENT_ID="your_xero_client_id"
XERO_CLIENT_SECRET="your_xero_client_secret"

# Xero Access Token (obtained after OAuth2 flow)
XERO_ACCESS_TOKEN="your_xero_access_token"

# Xero Base URL
XERO_BASE_URL="https://api.xero.com/api.xro/2.0/"

# OpenAI (Azure or standard) - used in journals for name extraction
OPENAI_API_KEY="your_openai_api_key"
OPENAI_API_BASE="https://your-azure-openai-resource.openai.azure.com/"
OPENAI_API_VERSION="2024-02-15-preview"
OPENAI_API_TYPE="azure"
OPENAI_MODEL="gpt-4o"

# Application User ID (internal user identifier to scope data)
APP_USER_ID="1"
